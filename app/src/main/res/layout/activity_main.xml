<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0e0e0e"
    tools:context=".MainActivity">

    <!-- ... existing header ... -->

    <!-- Download UI (Hidden by default) -->
    <LinearLayout
        android:id="@+id/downloadContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/composerBar">

        <TextView
            android:id="@+id/downloadStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="AI Model Missing"
            android:textColor="#ffffff" />

        <ProgressBar
            android:id="@+id/downloadProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:indeterminate="true" />

        <Button
            android:id="@+id/downloadButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:text="Download Model (~1.1GB)" />
    </LinearLayout>

    <!-- Composer Bar ... -->

    <!-- Status Header -->
    <TextView
        android:id="@+id/statusTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="PhoneAIOS"
        android:textColor="#ffffff"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/statusSub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Offline Agent Active"
        android:textColor="#888888"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusTitle" />

    <!-- Action Log (Glassmorphism inspired) -->
    <ScrollView
        android:id="@+id/logScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="24dp"
        android:background="@drawable/glass_card"
        android:padding="16dp"
        app:layout_constraintBottom_toTopOf="@+id/composerBar"
        app:layout_constraintTop_toBottomOf="@id/statusSub">

        <TextView
            android:id="@+id/actionLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="> Ready for commands..."
            android:textColor="#00ffcc" />
    </ScrollView>

    <!-- Composer Bar (Cursor 2.0 Style) -->
    <LinearLayout
        android:id="@+id/composerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@drawable/composer_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <EditText
            android:id="@+id/commandInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Ask PhoneAI to do something..."
            android:padding="12dp"
            android:textColor="#ffffff"
            android:textColorHint="#555555" />

        <ImageButton
            android:id="@+id/micButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/mic_bg"
            android:src="@android:drawable/ic_btn_speak_now"
            app:tint="#ffffff" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
